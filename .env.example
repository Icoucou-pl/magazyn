# PRZYKŁAD - skopiuj jako .env i wpisz prawdziwe wartości
# .env nigdy nie idzie do GitHuba!

# Baza danych - osobne pola żeby nie URL-encodować hasła
DB_HOST=localhost
DB_PORT=5432
DB_NAME=magazyn
DB_USER=postgres
DB_PASSWORD=twoje_haslo

# CORS - adresy z których frontend może się łączyć
ALLOWED_ORIGINS=http://localhost:3000

# Domyślny lead time
DEFAULT_LEAD_TIME_DAYS=90
